DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
BRIDGE_ADDR=127.0.0.1:11435
LOG_LEVEL=info

# Optional: map Codex model names to DeepSeek models
# CRABRIDGE_MODEL_MAP=gpt-5.4:deepseek-chat,gpt-5.5:deepseek-reasoner

# Optional: deny specific tools from upstream requests
# CRABRIDGE_TOOL_DENYLIST=spawn_agent,wait_agent

CACHE_ENABLED=false
CACHE_TTL_SECS=300
CACHE_MAX_ENTRIES=1000
RATE_LIMIT_RPS=0
MAX_SESSIONS=256
SESSION_TTL_HOURS=168
SESSION_DB=data/crabridge.db
# true disables SQLite persistence
SESSION_MEMORY_ONLY=false
