{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default CrabBridge desktop permissions",
  "windows": ["settings", "welcome"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "shell:allow-open",
    "autostart:default",
    "notification:default"
  ]
}
