{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrabBridge",
  "version": "0.1.0",
  "identifier": "com.crabbridge.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "CrabBridge desktop tray manager for Codex",
    "longDescription": "Runs the CrabBridge HTTP proxy in the background, with Codex setup, keychain storage, and an admin dashboard.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
